{
  "name": "kasiapps/framework",
  "description": "The Kasi Framework.",
  "keywords": [
    "framework",
    "kasi",
    "inertia"
  ],
  "license": "MIT",
  "homepage": "https://kasiapp.com",
  "support": {
    "issues": "https://github.com/kasiapps/framework/issues",
    "source": "https://github.com/kasiapps/framework"
  },
  "authors": [
    {
      "name": "Jetstream Labs, LLC.",
      "email": "hello@jetstreamlabs.com"
    },
    {
      "name": "Taylor Otwell",
      "email": "taylor@laravel.com"
    }
  ],
  "require": {
    "php": "^8.3",
    "composer-runtime-api": "^2.2",
    "dragonmantank/cron-expression": "^3.4",
    "illuminate/auth": "^12.17.0",
    "illuminate/broadcasting": "^12.17.0",
    "illuminate/bus": "^12.17.0",
    "illuminate/cache": "^12.17.0",
    "illuminate/collections": "^12.17.0",
    "illuminate/config": "^12.17.0",
    "illuminate/console": "^12.17.0",
    "illuminate/container": "^12.17.0",
    "illuminate/contracts": "^12.17.0",
    "illuminate/database": "^12.17.0",
    "illuminate/encryption": "^12.17.0",
    "illuminate/events": "^12.17.0",
    "illuminate/filesystem": "^12.17.0",
    "illuminate/hashing": "^12.17.0",
    "illuminate/http": "^12.17.0",
    "illuminate/log": "^12.17.0",
    "illuminate/macroable": "^12.17.0",
    "illuminate/pagination": "^12.17.0",
    "illuminate/pipeline": "^12.17.0",
    "illuminate/queue": "^12.17.0",
    "illuminate/support": "^12.17.0",
    "illuminate/testing": "^12.17.0",
    "illuminate/translation": "^12.17.0",
    "illuminate/validation": "^12.17.0",
    "illuminate/view": "^12.17.0",
    "laravel/prompts": "^0.3.5",
    "nikic/fast-route": "^1.3",
    "nyholm/psr7": "^1.8",
    "symfony/console": "^7.3",
    "symfony/error-handler": "^7.3",
    "symfony/http-foundation": "^7.3",
    "symfony/http-kernel": "^7.3",
    "symfony/mime": "^7.3",
    "symfony/psr-http-message-bridge": "^7.3",
    "symfony/var-dumper": "^7.3",
    "vlucas/phpdotenv": "^5.6.2"
  },
  "require-dev": {
    "laravel/tinker": "^2.10",
    "mockery/mockery": "^1.6.12",
    "pestphp/pest": "^3.8",
    "phpstan/phpstan": "^2.1",
    "zenphp/fixr": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Laravel\\Lumen\\": "src/"
    },
    "files": [
      "src/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "test:coverage": "pest --coverage --min=100",
    "analyse": "phpstan analyse",
    "analyse:fix": "phpstan analyse --generate-baseline"
  },
  "extra": {
    "branch-alias": {
      "dev-master": "1.x-dev"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
