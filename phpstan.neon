parameters:
	level: 1
	paths:
		- src
	excludePaths:
		- src/helpers.php
	ignoreErrors:
		# Optional dependencies that may not be installed
		- '#Class Illuminate\\Redis\\RedisManager not found#'
		- '#Class Illuminate\\Redis\\Connections\\Connection not found#'
		- '#Class Illuminate\\Database\\Eloquent\\Factory not found#'
